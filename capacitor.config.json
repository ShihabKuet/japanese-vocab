{
  "appId":   "com.japanesevocab.app",
  "appName": "Japanese Vocab",
  "webDir":  "dist",

  "android": {
    "allowMixedContent": true,
    "backgroundColor":   "#fef3e2",
    "androidScheme":     "https"
  },

  "plugins": {
    "SplashScreen": {
      "launchShowDuration":     2000,
      "backgroundColor":        "#fef3e2",
      "androidSplashResourceName": "splash",
      "showSpinner":            false,
      "launchFadeOutDuration":  500
    }
  }
}
